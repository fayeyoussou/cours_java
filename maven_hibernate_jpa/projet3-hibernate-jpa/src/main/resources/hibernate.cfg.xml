        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>

        <mapping class="sn.cours.model.Categorie"/>
        <mapping class="sn.cours.model.Produit"/>
    </session-factory>
    -->


    <!-- ============================================================
         CONFIG POSTGRESQL — exemple, port 5432, owod/owod
         ============================================================ -->
    <!--
